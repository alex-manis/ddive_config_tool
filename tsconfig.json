{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Node",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "rootDir": "src/client",
    "outDir": "public/client",
    "forceConsistentCasingInFileNames": true
  },
  "include": ["src/client/**/*"]
}
